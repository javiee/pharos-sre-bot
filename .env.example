# Copy to `.env` and fill in. `.env` is gitignored — never commit real tokens.
# Read by docker compose (for the grafana-mcp container) and by the agent
# (pydantic-settings reads this same file for local dev).

# --- Grafana MCP (docker compose) ---
GRAFANA_URL=https://grafana.prod.internal.p2p.org
# READ-ONLY Grafana service-account token (Viewer role / read-only scopes).
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# --- Agent → dependencies (already the defaults, shown for clarity) ---
VECTOR_DB_URL=http://localhost:6333
# SSE endpoint exposed by the grafana-mcp container (verify the /sse path for your image tag).
GRAFANA_MCP_URL=http://localhost:8000/sse

# --- LLM (local llama-swap) ---
LLM_BASE_URL=http://192.168.10.127:9090/v1
LLM_API_KEY=sk-no-key-required

# --- Local runbook ingestion ---
LOCAL_RUNBOOK_PATH=/Users/jcaro/repos/automation-agent/runbooks
